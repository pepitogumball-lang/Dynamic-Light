{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.player.offhand_hold": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        { "holding": "query.get_equipped_item_name('offhand') != ''" }
                    ]
                },
                "holding": {
                    "animations": [ "animation.player.third_person_offhand_hold" ],
                    "transitions": [
                        { "default": "query.get_equipped_item_name('offhand') == ''" }
                    ]
                }
            }
        }
    }
}
